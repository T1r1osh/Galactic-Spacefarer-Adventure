{
  "name": "galactic-spacefarer",
  "version": "1.0.0",
  "dependencies": {
    "@sap/cds": "^9"
  },
  "devDependencies": {
    "@cap-js/cds-typer": "^0.38.0",
    "@cap-js/cds-types": "^0.15.0",
    "@cap-js/sqlite": "^2",
    "@types/node": "^24.0.0",
    "tsx": "^4",
    "typescript": "^5",
    "cds-plugin-ui5": "^0.13.0"
  },
  "scripts": {
    "start": "cds-serve",
    "lint": "eslint .",
    "watch-galacticlistreport": "cds watch --open galacticlistreport/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "imports": {
    "#cds-models/*": "./@cds-models/*/index.js"
  },
  "cds": {
    "requires": {
      "auth": {
        "kind": "basic",
        "users": {
          "admin": {
            "password": "admin",
            "roles": [
              "admin"
            ],
            "attr": {
              "planet": "Earth"
            }
          },
          "mars": {
            "password": "mars",
            "roles": [
              "user"
            ],
            "attr": {
              "planet": "Mars"
            }
          },
          "earth": {
            "password": "earth",
            "roles": [
              "user"
            ],
            "attr": {
              "planet": "Earth"
            }
          }
        }
      }
    }
  },
  "workspaces": [
    "app/*"
  ],
  "overrides": {
    "@eslint/js": "^9.0.0"
  },
  "sapux": [
    "app/galacticlistreport"
  ]
}
